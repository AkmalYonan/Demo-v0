  npcName: Ambatukam Guard
  npcPortrait: {fileID: 0}
  lines:
  - Kamu! Siapa kamu ?
  - Kamu adalah orang asing!
  - Bisakah kamu perkenalkan diri ?
  - Hah?! Terdampar ?
  - Baik! Tapi maukah kamu membantu saya ?
  choices:
  - triggerLineIndex: 2
    choice1Text: Baik! Nama saya Bayu, saya terdampar disini. Saya tidak tau ini
      dimana bisakah kamu membantu saya ?
    choice1JumpIndex: 3
    choice1TriggerQuest: {fileID: 0}
    choice2Text: Tidak mau! saya tidak mau!
    choice2JumpIndex: -1
    choice2TriggerQuest: {fileID: 0}
  - triggerLineIndex: 4
    choice1Text: Baik saya akan membantu anda!
    choice1JumpIndex: -1
    choice1TriggerQuest: {fileID: 11400000, guid: b209a508e8e225d47969ec917fa0793d,
      type: 2}
    choice2Text: Tidak! Tidak mau!
    choice2JumpIndex: -1
    choice2TriggerQuest: {fileID: 0}
